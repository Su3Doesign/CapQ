---
const items = [
  "117+ Bank & NBFC Partners",
  "Hyderabad",
  "MSME Specialists",
  "Zero Cost Advisory",
  "4-Hour Response",
  "Working Capital",
  "Term Loans",
  "LAP",
  "CGTMSE",
  "Project Finance",
  "Trade Finance",
  "Invoice Discounting",
  "Equipment Finance",
  "Home Loans",
  "Personal Loans",
  "Education Loans",
];

const rowA = [...items, ...items];
const rowB = [...items.slice(8), ...items.slice(0, 8), ...items.slice(8), ...items.slice(0, 8)];
---

<section class="relative py-10">
  <p class="reveal mb-6 text-center font-mono text-[10px] uppercase tracking-[0.2em] text-ink-faint">
    <span class="hl-lime">Every kind of capital</span> &nbsp;·&nbsp; one trusted advisory
  </p>

  <div class="reveal flex w-screen flex-col gap-2.5">
    <!-- Row A -->
    <div class="group relative overflow-hidden" style="-webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)">
      <div class="flex w-max gap-2.5 animate-marquee group-hover:[animation-play-state:paused]">
        {rowA.map((item) => (
          <span class="glass-card inline-flex shrink-0 items-center gap-2 rounded-full px-4 py-2 text-[11px] font-medium text-ink-soft ring-1 ring-white/20">
            <span class="h-1.5 w-1.5 rounded-full bg-green/60"></span>
            {item}
          </span>
        ))}
      </div>
    </div>

    <!-- Row B -->
    <div class="group relative overflow-hidden" style="-webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)">
      <div class="flex w-max gap-2.5 animate-marquee-rev group-hover:[animation-play-state:paused]">
        {rowB.map((item) => (
          <span class="glass-card inline-flex shrink-0 items-center gap-2 rounded-full px-4 py-2 text-[11px] font-medium text-ink-soft ring-1 ring-white/20">
            <span class="h-1.5 w-1.5 rounded-full bg-lime/80"></span>
            {item}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>