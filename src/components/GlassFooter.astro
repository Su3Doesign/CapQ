<footer class="reveal relative px-5 pb-16 pt-10 text-center">
  <div class="glass-panel glass-deep mx-auto mb-8 max-w-2xl p-8">
    <div class="mb-5 flex justify-center">
      <img src={import.meta.env.BASE_URL + '/capq-logo.png'} alt="CapQ" class="h-10 w-auto opacity-80" />
    </div>
    <p class="mx-auto mb-5 max-w-[44ch] font-display text-lg font-medium leading-snug tracking-tight text-ink-soft">
      The right capital, structured the right way — for businesses
      <span class="text-green-deep"> and the lenders who back them.</span>
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <span class="glass-card inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 font-mono text-[9px] uppercase tracking-[0.14em] text-ink-faint">
        <span class="h-1 w-1 rounded-full bg-green"></span>
        117+ Bank & NBFC Partners
      </span>
      <span class="glass-card inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 font-mono text-[9px] uppercase tracking-[0.14em] text-ink-faint">
        <span class="h-1 w-1 rounded-full bg-lime"></span>
        Hyderabad
      </span>
      <span class="glass-card inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 font-mono text-[9px] uppercase tracking-[0.14em] text-ink-faint">
        <span class="h-1 w-1 rounded-full bg-green-bright"></span>
        MSME · Housing · Education
      </span>
    </div>
  </div>

  <p class="font-mono text-[10px] tracking-[0.14em] text-ink-faint/70" id="year">
    © CapQ · Right Capital. Structured Right.
  </p>
</footer>