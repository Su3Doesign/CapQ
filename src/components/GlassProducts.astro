---
const products = [
  { cat: "Business Finance", items: [
    "MSME Working Capital",
    "Term Loan",
    "Equipment Finance",
    "CGTMSE Collateral-free",
    "Loan Against Property",
    "Trade Finance",
    "Bill / Invoice Discounting",
    "Project Finance",
    "Bank Guarantee",
    "Balance Transfer"
  ]},
  { cat: "Personal & Property", items: [
    "Home & Mortgage",
    "Personal Loan",
    "Vehicle Loan",
    "Education Loan"
  ]},
  { cat: "Sector Specialist", items: [
    "Healthcare Professionals",
    "IT & Technology"
  ]}
];
---

<section class="relative px-5 py-20">
  <div class="mx-auto max-w-5xl">
    <div class="reveal mb-12 text-center">
      <span class="font-hand text-xl text-green-deep">what we arrange</span>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        Capital for <span class="hl-lime">every stage</span>
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((group, i) => (
        <div class={`glass-panel tilt-card p-6 ${i === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          <h3 class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.12em] text-green-deep">
            {group.cat}
          </h3>
          <ul class="space-y-2.5">
            {group.items.map(item => (
              <li class="flex items-start gap-2 text-sm text-ink-soft">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-green" viewBox="0 0 16 16" fill="none"><path d="M3 8l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="reveal mt-10 text-center">
      <p class="text-sm text-ink-faint">Not sure what fits? <a href="https://wa.me/917995290768" target="_blank" rel="noopener" class="font-semibold text-green-deep underline-offset-2 hover:underline">Speak to a strategist</a> — we'll diagnose the right structure.</p>
    </div>
  </div>
</section>